lass Solution {
    public ListNode removeElements(ListNode head, int val) {
      ListNode start = new ListNode(0);
        start.next = head;
        ListNode node = start;
        while (node.next != null) {
            if (node.next.val == val) {
                node.next = node.next.next;
            } else {
                node = node.next;
            }
        }
        return start.next;
    }
}  
