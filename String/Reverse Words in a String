class Solution {
    public String reverseWords(String s) {
          s = s.trim();

        String[] parts = s.split("\\s+");

        int left = 0;
        int right = parts.length - 1;

        while (left < right) {
            String current = parts[left];
            parts[left] = parts[right];
            parts[right] = current;

            left++;
            right--;
        }

        return String.join(" ", parts);
    }
}
