class Solution {
    public boolean isPalindrome(String s) {
         int left = 0;
        int right = s.length() - 1;
        s = s.toLowerCase();
        while (left < right) {
            char first = s.charAt(left);
            char last = s.charAt(right);

            if (!(first >= 'a' && first <= 'z' || first >= '0' && first <= '9')) {
                left++;
                continue;
            }
            if (!(last >= 'a' && last <= 'z' || last >= '0' && last <= '9')) {
                right--;
                continue;
            }
            if (first != last) {
                return false;
            }
            left++;
            right--;
        }
        return true;
    }
}
