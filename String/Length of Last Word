class Solution {
    public int lengthOfLastWord(String s) {
       int len = s.length();
        int end = len - 1;

        while (end > 0 && s.charAt(end) == ' ') {
            end--;
        }

        int start = end;

        while (start > -1 && s.charAt(start) != ' ') {
            start--;
        }

        return end - start;
    }
}
